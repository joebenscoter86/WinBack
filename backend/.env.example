# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_APP_SECRET=absec_...
# WIN-21: webhook signing secret. Generated when you add the Connect webhook
# endpoint in the Stripe Dashboard (subscribed to charge.dispute.* events).
STRIPE_WEBHOOK_SECRET=whsec_...

# WIN-24: hybrid billing — success fee (15%) + Pro ($79/mo)
# Create these in Stripe Dashboard > Products:
#   1. Pro: recurring $79/mo → STRIPE_PRICE_PRO_MONTHLY
#   2. Usage fee: metered price linked to a Meter with event_name='dispute_won_fee',
#      aggregation=sum, customer mapping=payload.stripe_customer_id → STRIPE_PRICE_USAGE_FEE
# Register a second webhook endpoint (platform, not Connect) for subscription events
# → STRIPE_BILLING_WEBHOOK_SECRET. Subscribe to customer.subscription.{created,updated,
# deleted}, invoice.payment_{succeeded,failed}.
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_USAGE_FEE=price_...
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...

# WIN-21: Vercel cron auth. Vercel sends `Authorization: Bearer ${CRON_SECRET}`
# with cron-triggered requests when this is set. Required in prod.
CRON_SECRET=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@winbackpay.com

# Sentry — error tracking (WIN-32)
# DSN is required to send events; the others gate source-map upload at build time.
SENTRY_DSN=https://...ingest.us.sentry.io/...
SENTRY_ORG=jb-technology-llc
SENTRY_PROJECT=winback-backend
SENTRY_AUTH_TOKEN=                # required only on Vercel for sourcemap upload
SENTRY_ENVIRONMENT=               # optional override; defaults to VERCEL_ENV
